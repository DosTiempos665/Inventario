================================================================ */
function exportPDF(){
  window.print();
}

function exportExcel(){
  const rows = [["Categoría","Producto","Cantidad comprada","Unidad","Ideal de reorden"]];
  PRODUCTS.forEach(p=>{
    if(!ownerActiveCats.includes(p.cat)) return;
    const input = document.getElementById(`purchase-${p.id}`);
    const value = input ? input.value : "";
    if(input){
      rows.push([CATEGORIES[p.cat], p.name, value, p.unit, p.ideal]);
    }
  });
  const csv = rows.map(r=>r.map(c=>`"${String(c).replace(/"/g,'""')}"`).join(",")).join("\n");
  const blob = new Blob(["\uFEFF"+csv], {type:"text/csv;charset=utf-8;"});
  const url = URL.createObjectURL(blob);
  const a = document.createElement("a");
  a.href = url;
  a.download = `reporte_compras_dos_tiempos_${toDateInput(new Date())}.csv`;
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);
  URL.revokeObjectURL(url);
}

