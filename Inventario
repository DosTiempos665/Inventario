<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Inventario — Dos Tiempos</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
/* ============================================================
   TOKENS — paleta "Dos Tiempos"
============================================================ */
:root{
  --cream:#fdfcf9;
  --cream-deep:#f6f3ec;
  --olive:#4a5849;
  --olive-soft:#6f7d6c;
  --gold:#c2b29a;
  --gold-deep:#a98f6c;
  --gold-fade:rgba(194,178,154,0.16);
  --white:#ffffff;
  --danger:#a85c4a;
  --ok:#5c7d5e;
  --border:rgba(194,178,154,0.35);
  --shadow:0 2px 4px rgba(74,88,73,0.05), 0 14px 40px rgba(74,88,73,0.08);
  --f-display:'Cormorant Garamond', Georgia, serif;
  --f-body:'Montserrat', system-ui, sans-serif;
  --r:10px;
  --ease:cubic-bezier(.25,1,.5,1);
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;}
body{
  background:var(--cream);
  font-family:var(--f-body);
  color:var(--olive);
  -webkit-font-smoothing:antialiased;
  min-height:100vh;
  padding:32px 16px 80px;
  display:flex;flex-direction:column;align-items:center;
}

/* ============================================================
   SHELL / CARD
============================================================ */
.shell{max-width:1080px;width:100%;}

.card{
  background:var(--white);
  border:1px solid var(--border);
  border-radius:var(--r);
  box-shadow:var(--shadow);
  overflow:hidden;
  margin-bottom:28px;
}

/* ============================================================
   HEADER
============================================================ */
.header{
  padding:40px 48px 32px;
  border-bottom:1px solid var(--border);
  background:linear-gradient(160deg,#ffffff 60%, var(--gold-fade) 100%);
  position:relative;
  display:flex;
  flex-wrap:wrap;
  align-items:flex-end;
  justify-content:space-between;
  gap:20px;
}
.header::before{
  content:'';position:absolute;top:0;left:0;right:0;height:3px;
  background:linear-gradient(90deg,transparent,var(--gold),transparent);
}
.header-text .eyebrow{
  font-size:.7rem;font-weight:500;letter-spacing:.28em;text-transform:uppercase;
  color:var(--gold-deep);margin-bottom:10px;
}
.header-text h1{
  font-family:var(--f-display);font-size:clamp(1.9rem,4vw,2.6rem);
  font-weight:500;color:var(--olive);letter-spacing:.04em;line-height:1.1;
}
.header-text .subtitle{
  font-family:var(--f-display);font-style:italic;font-size:1.15rem;
  color:var(--gold-deep);margin-top:6px;
}

/* ============================================================
   BOTONES BASE
============================================================ */
.btn{
  font-family:var(--f-body);
  font-size:.78rem;font-weight:500;letter-spacing:.12em;text-transform:uppercase;
  padding:12px 26px;border-radius:6px;cursor:pointer;
  border:1px solid var(--gold);background:transparent;color:var(--olive);
  transition:background .25s var(--ease),color .25s var(--ease),
             border-color .25s var(--ease),box-shadow .25s var(--ease);
  white-space:nowrap;
}
.btn:hover{background:var(--gold-fade);}
.btn.solid{background:var(--olive);color:var(--white);border-color:var(--olive);}
.btn.solid:hover{background:#3b463a;}
.btn.active{background:var(--olive);color:var(--white);border-color:var(--olive);
  box-shadow:0 4px 14px rgba(74,88,73,.18);}
.btn.small{padding:9px 18px;font-size:.7rem;}
.btn:focus-visible{outline:2px solid var(--olive);outline-offset:2px;}

/* ============================================================
   TABS DE INVENTARIO
============================================================ */
.tabs{
  display:flex;gap:12px;padding:24px 48px 0;flex-wrap:wrap;
}
@media (max-width:560px){.tabs{padding:20px 20px 0;}}

/* ============================================================
   CONTENIDO PRINCIPAL
============================================================ */
.content{padding:32px 48px 48px;}
@media (max-width:560px){.content{padding:24px 20px 36px;}}

.panel{display:none;animation:fadeUp .35s var(--ease) both;}
.panel.active{display:block;}
@keyframes fadeUp{from{opacity:0;transform:translateY(10px);}to{opacity:1;transform:translateY(0);}}

/* ============================================================
   SECCIÓN / CATEGORÍA
============================================================ */
.section{margin-bottom:48px;}
.section:last-child{margin-bottom:0;}
.section-head{
  display:flex;align-items:center;gap:16px;margin-bottom:24px;
}
.section-head .diamond{
  width:8px;height:8px;background:var(--gold);transform:rotate(45deg);flex-shrink:0;
}
.section-head h2{
  font-family:var(--f-display);font-size:clamp(1.3rem,2.4vw,1.7rem);
  font-weight:500;letter-spacing:.12em;text-transform:uppercase;color:var(--olive);
  white-space:nowrap;
}
.section-head .line{flex:1;height:1px;background:linear-gradient(to right,var(--border) 60%,transparent);}

.grid{
  display:grid;grid-template-columns:repeat(2,1fr);gap:18px;
}
@media (max-width:720px){.grid{grid-template-columns:1fr;}}

/* ============================================================
   TARJETA DE PRODUCTO (trabajador)
============================================================ */
.product{
  border:1px solid var(--border);border-radius:var(--r);
  padding:18px 20px;background:var(--cream);
  transition:border-color .2s var(--ease), box-shadow .2s var(--ease);
}
.product:hover{border-color:var(--gold-deep);box-shadow:var(--shadow);}
.product.faltante{
  border-color:var(--olive);background:linear-gradient(to right, rgba(74,88,73,.05), var(--cream) 60%);
}

.product-top{
  display:flex;align-items:flex-start;justify-content:space-between;gap:10px;margin-bottom:6px;
}
.product-name{
  display:flex;align-items:center;gap:10px;
}
.dot{
  width:9px;height:9px;background:var(--gold);transform:rotate(45deg);flex-shrink:0;
  transition:background .2s var(--ease);
}
.product.faltante .dot{background:var(--olive);}
.product-name span{
  font-family:var(--f-display);font-size:1.25rem;font-weight:500;color:var(--olive);
}
.product-qty{
  font-family:var(--f-display);font-weight:600;font-size:1.05rem;color:var(--gold-deep);
  white-space:nowrap;flex-shrink:0;
}

.slider-row{margin:14px 0 12px;}
input[type=range]{
  width:100%;-webkit-appearance:none;appearance:none;
  height:4px;border-radius:4px;background:var(--border);outline:none;cursor:pointer;
}
input[type=range]::-webkit-slider-thumb{
  -webkit-appearance:none;appearance:none;width:18px;height:18px;border-radius:50%;
  background:var(--gold-deep);border:2px solid var(--white);box-shadow:0 1px 4px rgba(74,88,73,.3);
  transition:transform .15s var(--ease), background .15s var(--ease);
}
input[type=range]::-webkit-slider-thumb:hover{transform:scale(1.15);background:var(--olive);}
input[type=range]::-moz-range-thumb{
  width:18px;height:18px;border-radius:50%;background:var(--gold-deep);
  border:2px solid var(--white);box-shadow:0 1px 4px rgba(74,88,73,.3);cursor:pointer;
}
.product.faltante input[type=range]::-webkit-slider-thumb,
.product.faltante input[type=range]::-moz-range-thumb{background:var(--olive);}

.product-bottom{display:flex;justify-content:flex-end;}

.toggle-faltante{
  font-size:.68rem;font-weight:500;letter-spacing:.1em;text-transform:uppercase;
  padding:8px 16px;border-radius:5px;cursor:pointer;border:1px solid var(--gold);
  background:var(--gold-fade);color:var(--gold-deep);
  transition:background .2s var(--ease),color .2s var(--ease),border-color .2s var(--ease);
}
.toggle-faltante.on{background:var(--olive);color:var(--white);border-color:var(--olive);}

/* Botón discreto para agregar comentarios por producto */
.comment-toggle{
  font-size:.7rem;font-weight:500;color:var(--olive-soft);
  background:none;border:none;cursor:pointer;
  text-decoration:underline;text-decoration-color:var(--border);
  padding:4px 0;transition:color .2s var(--ease);
}
.comment-toggle:hover{color:var(--gold-deep);}
.comment-toggle.has-text{color:var(--gold-deep);font-weight:600;}

.comment-box{display:none;margin-top:10px;}
.comment-box.open{display:block;}
.comment-box textarea{
  width:100%;min-height:56px;resize:vertical;
  font-family:var(--f-body);font-size:.8rem;color:var(--olive);
  border:1px solid var(--border);border-radius:6px;padding:8px 10px;
  background:var(--white);outline:none;
}
.comment-box textarea:focus{border-color:var(--gold-deep);}

/* ============================================================
   RESUMEN DE FALTANTES
============================================================ */
.missing-card{
  background:var(--cream-deep);border:1px solid var(--border);border-radius:var(--r);
  padding:24px 28px;
}
.missing-empty{font-size:.85rem;color:var(--olive-soft);font-style:italic;}
.missing-list{list-style:none;display:flex;flex-direction:column;gap:10px;}
.missing-list li{
  display:flex;align-items:center;gap:12px;font-size:.92rem;color:var(--olive);
}
.missing-list li .dot{background:var(--olive);}
.missing-list li b{font-family:var(--f-display);font-size:1.1rem;font-weight:600;}
.missing-list li small{color:var(--olive-soft);margin-left:auto;}

/* ============================================================
   BARRA INFERIOR DE GUARDADO
============================================================ */
.save-bar{
  display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:14px;
  border-top:1px solid var(--border);padding:24px 48px;background:var(--cream-deep);
}
@media (max-width:560px){.save-bar{padding:20px;}}
.save-status{font-size:.8rem;color:var(--olive-soft);}
.save-status b{color:var(--olive);}

/* El campo de nombre ocupa ancho fijo en escritorio, completo en móvil */
.employee-field{min-width:220px;}
.employee-field input{width:100%;}

@media (max-width:720px){
  .save-bar{flex-direction:column;align-items:stretch;}
  .employee-field{min-width:0;width:100%;}
  .save-status{order:2;text-align:left;}
  .save-bar > .btn{order:3;width:100%;text-align:center;}
}

/* ============================================================
   MODAL CONTRASEÑA
============================================================ */
dialog{
  border:none;border-radius:var(--r);padding:0;box-shadow:var(--shadow);
  max-width:380px;width:90%;
}
dialog::backdrop{background:rgba(74,88,73,.35);backdrop-filter:blur(2px);}
.modal-inner{padding:32px 32px 28px;}
.modal-inner h3{
  font-family:var(--f-display);font-size:1.5rem;font-weight:500;color:var(--olive);
  margin-bottom:6px;
}
.modal-inner p{font-size:.85rem;color:var(--olive-soft);margin-bottom:20px;}
.modal-inner input[type=password]{
  width:100%;padding:12px 14px;border:1px solid var(--border);border-radius:6px;
  font-family:var(--f-body);font-size:.95rem;color:var(--olive);background:var(--cream);
  margin-bottom:8px;outline:none;
}
.modal-inner input[type=password]:focus{border-color:var(--gold-deep);}
.modal-error{font-size:.78rem;color:var(--danger);min-height:1.2em;margin-bottom:12px;}
.modal-actions{display:flex;gap:10px;justify-content:flex-end;}

/* ============================================================
   VISTA DUEÑO — FILTROS
============================================================ */
.filters{
  display:flex;flex-wrap:wrap;gap:14px;align-items:flex-end;
  background:var(--cream-deep);border:1px solid var(--border);border-radius:var(--r);
  padding:20px 24px;margin-bottom:32px;
}
.field{display:flex;flex-direction:column;gap:6px;}
.field label{font-size:.68rem;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:var(--olive-soft);}
.field input, .field select{
  font-family:var(--f-body);font-size:.85rem;color:var(--olive);
  border:1px solid var(--border);border-radius:6px;padding:9px 12px;background:var(--white);
  outline:none;
}
.field input:focus,.field select:focus{border-color:var(--gold-deep);}
.field.grow{flex:1;min-width:160px;}

/* ============================================================
   FILA DE COMPRA (vista dueño)
============================================================ */
.purchase-row{
  display:flex;align-items:center;gap:14px;padding:12px 0;
  border-bottom:1px solid var(--border);
}
.purchase-row:last-child{border-bottom:none;}
.purchase-row .dot{flex-shrink:0;}
.purchase-row .pname{
  font-family:var(--f-display);font-size:1.15rem;font-weight:500;color:var(--olive);
  flex:1;min-width:120px;
}
.purchase-row .ideal{
  font-size:.75rem;color:var(--olive-soft);min-width:90px;text-align:right;
}
.purchase-row input[type=text]{
  width:90px;text-align:right;font-family:var(--f-body);font-size:.85rem;
  border:1px solid var(--border);border-radius:6px;padding:8px 10px;color:var(--olive);
  background:var(--white);outline:none;
}
.purchase-row input[type=text]:focus{border-color:var(--gold-deep);}
.purchase-row .unit{font-size:.78rem;color:var(--olive-soft);min-width:30px;}

@media (max-width:560px){
  .purchase-row{flex-wrap:wrap;}
  .purchase-row .ideal{order:4;width:100%;text-align:left;}
}

/* ============================================================
   FOOTER / PERFIL
============================================================ */
.owner-footer{
  display:flex;align-items:center;gap:12px;padding:20px 48px;
  border-top:1px solid var(--border);background:var(--cream-deep);
}
@media (max-width:560px){.owner-footer{padding:18px 20px;}}
.profile-icon{
  width:38px;height:38px;border-radius:50%;background:var(--olive);color:var(--white);
  display:flex;align-items:center;justify-content:center;font-family:var(--f-display);
  font-size:1.1rem;font-weight:600;flex-shrink:0;
}
.profile-meta{font-size:.78rem;color:var(--olive-soft);line-height:1.4;}
.profile-meta b{color:var(--olive);font-weight:600;}

/* ============================================================
   UTILIDADES
============================================================ */
.hidden{display:none !important;}
.reduce-motion-safe{}
@media (prefers-reduced-motion: reduce){
  *,*::before,*::after{transition:none !important;animation:none !important;}
}
</style>
</head>
<body>

<div class="shell">

  <!-- ====================================================
       VISTA TRABAJADOR
  ==================================================== -->
  <div id="view-worker">
    <div class="card">

      <!-- HEADER -->
      <header class="header">
        <div class="header-text">
          <p class="eyebrow">Inventario de "Dos Tiempos"</p>
          <h1>Dos Tiempos — Inventario Diario</h1>
          <p class="subtitle">Registro rápido de existencias</p>
        </div>
        <button class="btn" onclick="openOwnerModal()">Vista del Dueño</button>
      </header>

      <!-- TABS -->
      <nav class="tabs" id="worker-tabs">
        <button class="btn active" id="wtab-trad" onclick="switchWorkerTab('trad', this)">Inventario Tradicional</button>
        <button class="btn" id="wtab-esp" onclick="switchWorkerTab('esp', this)">Menú Especial</button>
      </nav>

      <!-- CONTENIDO -->
      <div class="content">
        <div id="wpanel-trad" class="panel active"></div>
        <div id="wpanel-esp" class="panel"></div>

        <!-- RESUMEN DE FALTANTES -->
        <div class="section" style="margin-top:8px;">
          <div class="section-head">
            <div class="diamond"></div>
            <h2>Resumen de Faltantes</h2>
            <div class="line"></div>
          </div>
          <div class="missing-card" id="missing-summary">
            <p class="missing-empty">No hay productos marcados como faltantes.</p>
          </div>
        </div>
      </div>

      <!-- GUARDAR -->
      <div class="save-bar">
        <div class="field employee-field">
          <label for="employee-name">Registrado por</label>
          <input type="text" id="employee-name" placeholder="Escribe tu nombre" autocomplete="off">
        </div>
        <p class="save-status">
          Última actualización: <b id="last-saved">sin registros aún</b><br>
          Registrado por: <b id="last-employee">—</b>
        </p>
        <button class="btn solid" onclick="saveInventory()">Guardar Inventario</button>
      </div>

    </div>
  </div>

  <!-- ====================================================
       VISTA DUEÑO
  ==================================================== -->
  <div id="view-owner" class="hidden">
    <div class="card">

      <!-- HEADER -->
      <header class="header">
        <div class="header-text">
          <p class="eyebrow">Inventario de "Dos Tiempos"</p>
          <h1>Dos Tiempos — Reportes de Inventario</h1>
          <p class="subtitle">Vista exclusiva del dueño</p>
        </div>
        <button class="btn" onclick="closeOwnerView()">Volver al Inventario (Trabajador)</button>
      </header>

      <!-- TABS -->
      <nav class="tabs" id="owner-tabs">
        <button class="btn active" id="otab-trad" onclick="switchOwnerTab('trad', this)">Inventario Tradicional</button>
        <button class="btn" id="otab-esp" onclick="switchOwnerTab('esp', this)">Menú Especial</button>
      </nav>

      <!-- CONTENIDO -->
      <div class="content">

        <!-- FILTROS -->
        <div class="filters">
          <div class="field">
            <label>Fecha de inicio</label>
            <input type="date" id="report-start">
          </div>
          <div class="field">
            <label>Fecha de fin</label>
            <input type="date" id="report-end">
          </div>
          <div class="field">
            <label>Período rápido</label>
            <select id="report-period" onchange="applyQuickPeriod()">
              <option value="">Personalizado</option>
              <option value="week">Última semana</option>
              <option value="month">Último mes</option>
            </select>
          </div>
          <div class="field grow">
            <label>Filtrar por categoría</label>
            <select id="report-category"></select>
          </div>
          <button class="btn solid" onclick="generateReport()">Generar Reporte</button>
        </div>

        <!-- HISTORIAL DE REGISTROS -->
        <div class="section">
          <div class="section-head">
            <div class="diamond"></div>
            <h2>Historial de Registros</h2>
            <div class="line"></div>
          </div>
          <div class="missing-card" id="history-log"></div>
        </div>

        <!-- REPORTE -->
        <div id="report-output"></div>

        <!-- ACCIONES -->
        <div style="display:flex;gap:12px;flex-wrap:wrap;margin-top:32px;">
          <button class="btn solid" onclick="savePurchases()">Guardar Reporte</button>
          <button class="btn" onclick="exportPDF()">Exportar a PDF</button>
          <button class="btn" onclick="exportExcel()">Exportar a Excel</button>
        </div>
        <p class="save-status" style="margin-top:14px;">Reporte guardado: <b id="purchases-saved">sin registros aún</b></p>
      </div>

      <!-- FOOTER PERFIL -->
      <footer class="owner-footer">
        <div class="profile-icon">DT</div>
        <div class="profile-meta">
          <b>Dueño · Dos Tiempos</b><br>
          Acceso exclusivo a reportes de inventario
        </div>
      </footer>

    </div>
  </div>

</div>

<!-- ====================================================
     MODAL CONTRASEÑA
==================================================== -->
<dialog id="owner-modal">
  <div class="modal-inner">
    <h3>Vista del Dueño</h3>
    <p>Ingresa la contraseña para acceder a los reportes de inventario.</p>
    <input type="password" id="owner-password" placeholder="Contraseña" autocomplete="off">
    <p class="modal-error" id="owner-error"></p>
    <div class="modal-actions">
      <button class="btn small" onclick="closeOwnerModal()">Cancelar</button>
      <button class="btn small solid" onclick="checkOwnerPassword()">Entrar</button>
    </div>
  </div>
</dialog>

<script>
/* ================================================================
   1. CONFIGURACIÓN GENERAL
================================================================ */

// Interruptor: activa o desactiva la sección "Menú Especial"
// tanto en la vista del trabajador como en la del dueño.
const menuEspecialDisponible = true;

// Contraseña de acceso a la vista del dueño (cámbiala libremente).
const OWNER_PASSWORD = "dostiempos2024";

// Categorías. id 10 = especial.
const CATEGORIES = {
  1: "Salsas y Base",
  2: "Carnes",
  3: "Quesos",
  4: "Frijol y Acompañamientos",
  5: "Waffles y Repostería",
  6: "Ingredientes de Repostería",
  7: "Omelette y Papas",
  8: "Bebidas y Jugos",
  9: "Batidos",
  10: "Especialidades (Menú Especial)"
};

/* ================================================================
   2. CATÁLOGO DE PRODUCTOS
   max  = capacidad máxima de referencia (100% del slider)
   step = incremento del slider
   ideal = nivel ideal de reorden (lúdico, usado en reportes)
================================================================ */
const PRODUCTS = [
  {id:"tomate", name:"Tomate", cat:1, unit:"kg", max:10, step:0.5, ideal:7},
  {id:"tomato_sauce", name:"Tomato Sauce", cat:1, unit:"kg", max:10, step:0.5, ideal:7},
  {id:"queso_crema", name:"Queso crema", cat:1, unit:"kg", max:10, step:0.5, ideal:7},
  {id:"chipotle", name:"Chipotle", cat:1, unit:"kg", max:10, step:0.5, ideal:7},
  {id:"cilantro", name:"Cilantro", cat:1, unit:"kg", max:10, step:0.5, ideal:7},
  {id:"pure_tomate", name:"Puré de tomate", cat:1, unit:"kg", max:10, step:0.5, ideal:7},
  {id:"cebolla_morada", name:"Cebolla morada", cat:1, unit:"kg", max:10, step:0.5, ideal:7},
  {id:"cebolla_blanca", name:"Cebolla blanca", cat:1, unit:"kg", max:10, step:0.5, ideal:7},
  {id:"ajo", name:"Ajo", cat:1, unit:"kg", max:10, step:0.5, ideal:7},
  {id:"sal", name:"Sal", cat:1, unit:"kg", max:10, step:0.5, ideal:7},
  {id:"pimienta", name:"Pimienta", cat:1, unit:"kg", max:10, step:0.5, ideal:7},
  {id:"totopos", name:"Totopos", cat:1, unit:"kg", max:10, step:0.5, ideal:7},
  {id:"rajas", name:"Rajas", cat:1, unit:"kg", max:10, step:0.5, ideal:7},
