// Determina si un producto está "Faltante": manual o porque la cantidad es 0.
function isFaltante(p){
  const item = inventoryState.items[p.id];
  return item.manualFaltante || item.qty <= 0;
}

// Formatea la cantidad con su unidad de forma legible.
function formatQty(p, qty){
  const decimals = p.step < 1 ? 1 : 0;
  return `${qty.toFixed(decimals)} ${p.unit}`;
}

// Construye el HTML de una tarjeta de producto.
function renderProductCard(p){
  const item = inventoryState.items[p.id];
  const faltante = isFaltante(p);
  return `
    <div class="product ${faltante?'faltante':''}" id="card-${p.id}">
      <div class="product-top">
        <div class="product-name">
          <span class="dot"></span>
          <span>${p.name}</span>
        </div>
        <div class="product-qty">◆ ${formatQty(p, item.qty)}</div>
      </div>
      <div class="slider-row">
        <input type="range" min="0" max="${p.max}" step="${p.step}"
               value="${item.qty}"
               oninput="updateQty('${p.id}', this.value)">
      </div>
      <div class="product-bottom" style="flex-direction:column;align-items:flex-start;gap:6px;">
        <button class="toggle-faltante ${item.manualFaltante?'on':''}"
                onclick="toggleFaltante('${p.id}')">
          Marcar como Faltante
        </button>
        <button class="comment-toggle ${item.comment?'has-text':''}" id="ctoggle-${p.id}"
                onclick="toggleCommentBox('${p.id}')">
          ${item.comment ? '✎ Ver / editar comentario' : '+ Agregar comentario'}
        </button>
      </div>
      <div class="comment-box" id="cbox-${p.id}">
        <textarea placeholder="Ej. llegó dañado, falta confirmar con proveedor..."
                  oninput="updateComment('${p.id}', this.value)">${item.comment || ""}</textarea>
      </div>
    </div>`;
}

// Renderiza todas las categorías de un grupo (tradicional o especial) en un panel.
function renderWorkerPanel(panelId, catIds){
  const panel = document.getElementById(panelId);
  let html = "";
  catIds.forEach(catId=>{
    const items = PRODUCTS.filter(p=>p.cat===catId);
    if(items.length===0) return;
    html += `
      <div class="section">
        <div class="section-head">
          <div class="diamond"></div>
          <h2>${CATEGORIES[catId]}</h2>
          <div class="line"></div>
        </div>
        <div class="grid">
          ${items.map(renderProductCard).join("")}
        </div>
      </div>`;
  });
  panel.innerHTML = html;
}

// Actualiza la cantidad de un producto al mover el slider.
function updateQty(id, value){
  const p = PRODUCTS.find(x=>x.id===id);
  inventoryState.items[id].qty = parseFloat(value);
  refreshCard(p);
  renderMissingSummary();
}

// Alterna el estado manual de "Faltante" para un producto.
function toggleFaltante(id){
  const p = PRODUCTS.find(x=>x.id===id);
  inventoryState.items[id].manualFaltante = !inventoryState.items[id].manualFaltante;
  refreshCard(p);
  renderMissingSummary();
}

// Muestra u oculta la caja de comentario de un producto.
function toggleCommentBox(id){
  const box = document.getElementById(`cbox-${id}`);
  box.classList.toggle("open");
  if(box.classList.contains("open")){
    box.querySelector("textarea").focus();
  }
}

// Guarda el texto del comentario en el estado y actualiza el botón discreto.
function updateComment(id, value){
  inventoryState.items[id].comment = value;
  const btn = document.getElementById(`ctoggle-${id}`);
  if(value.trim() !== ""){
    btn.textContent = "✎ Ver / editar comentario";
    btn.classList.add("has-text");
  } else {
    btn.textContent = "+ Agregar comentario";
    btn.classList.remove("has-text");
  }
}

// Refresca visualmente una sola tarjeta sin re-renderizar todo el panel.
function refreshCard(p){
  const item = inventoryState.items[p.id];
  const card = document.getElementById(`card-${p.id}`);
  if(!card) return;
  const faltante = isFaltante(p);
  card.classList.toggle("faltante", faltante);
  card.querySelector(".product-qty").textContent = `◆ ${formatQty(p, item.qty)}`;
  const btn = card.querySelector(".toggle-faltante");
  btn.classList.toggle("on", item.manualFaltante);
}

// Renderiza el panel de "Resumen de Faltantes".
function renderMissingSummary(){
  const container = document.getElementById("missing-summary");
  const missing = PRODUCTS.filter(isFaltante);
  if(missing.length===0){
    container.innerHTML = `<p class="missing-empty">No hay productos marcados como faltantes.</p>`;
    return;
  }
  container.innerHTML = `
    <ul class="missing-list">
      ${missing.map(p=>`
        <li>
          <span class="dot"></span>
          <b>${p.name}</b>
          <small>${CATEGORIES[p.cat]}</small>
        </li>`).join("")}
    </ul>`;
}

// Guarda el inventario actual en LocalStorage con marca de tiempo,
// y conserva un historial breve para los reportes del dueño.
function saveInventory(){
  const nameInput = document.getElementById("employee-name");
  const employeeName = nameInput.value.trim();

  // Validación: el nombre es obligatorio para identificar quién registró el inventario
  if(employeeName === ""){
    nameInput.style.borderColor = "var(--danger)";
    nameInput.focus();
    nameInput.placeholder = "Escribe tu nombre para poder guardar";
    return;
  }
  nameInput.style.borderColor = "";

  inventoryState.lastSaved = new Date().toISOString();
  inventoryState.lastEmployee = employeeName;
  persistInventory();

  // Guardar snapshot en el historial (para cálculos de reporte)
  const history = JSON.parse(localStorage.getItem("dt_history_v1") || "[]");
  history.push({
    date: inventoryState.lastSaved,
    employee: employeeName,
    items: JSON.parse(JSON.stringify(inventoryState.items))
  });
  // Conservar como máximo los últimos 120 registros
  while(history.length > 120) history.shift();
  localStorage.setItem("dt_history_v1", JSON.stringify(history));

  renderLastSaved();
}

function renderLastSaved(){
  const el = document.getElementById("last-saved");
  const elEmp = document.getElementById("last-employee");
  if(!inventoryState.lastSaved){
    el.textContent = "sin registros aún";
    elEmp.textContent = "—";
    return;
  }
  const d = new Date(inventoryState.lastSaved);
  el.textContent = d.toLocaleString("es-MX", {
    day:"2-digit", month:"short", year:"numeric", hour:"2-digit", minute:"2-digit"
  });
  elEmp.textContent = inventoryState.lastEmployee || "—";

  // Precargar el campo de nombre con el último empleado que guardó,
  // para agilizar registros consecutivos del mismo turno.
  const nameInput = document.getElementById("employee-name");
  if(nameInput && !nameInput.value){
    nameInput.value = inventoryState.lastEmployee || "";
  }
}

