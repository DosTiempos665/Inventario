================================================================ */
const LS_INVENTORY = "dt_inventory_v1";
const LS_PURCHASES = "dt_purchases_v1";

// Carga el inventario actual desde LocalStorage, o crea valores por defecto.
function loadInventory(){
  const raw = localStorage.getItem(LS_INVENTORY);
  if(raw){
    try { return JSON.parse(raw); } catch(e){ /* sigue abajo */ }
  }
  // Estado inicial: cada producto al 70% de su capacidad, sin faltantes manuales.
  const data = { items:{}, lastSaved:null, lastEmployee:null };
  PRODUCTS.forEach(p=>{
    data.items[p.id] = { qty: Math.round(p.max*0.7*100)/100, manualFaltante:false, comment:"" };
  });
  return data;
}

let inventoryState = loadInventory();

// Asegurar compatibilidad con inventarios guardados antes de agregar comentarios
PRODUCTS.forEach(p=>{
  if(!inventoryState.items[p.id]) {
    inventoryState.items[p.id] = { qty: Math.round(p.max*0.7*100)/100, manualFaltante:false, comment:"" };
  } else if(inventoryState.items[p.id].comment === undefined){
    inventoryState.items[p.id].comment = "";
  }
});

function persistInventory(){
  localStorage.setItem(LS_INVENTORY, JSON.stringify(inventoryState));
}

