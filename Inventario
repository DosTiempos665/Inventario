/* ================================================================
   9. GENERACIÓN DE REPORTES
   Lógica: para cada producto, se compara la cantidad registrada
   más antigua y más reciente dentro del rango de fechas.
   - Si el producto estuvo marcado "Faltante" en algún punto del
     rango, se asume que se realizó una compra de reabastecimiento
     hasta su nivel "ideal" (ideal de reorden).
   - Si no, la compra estimada es el incremento neto de existencias
     (cantidad final - cantidad inicial), si fue positivo.
   Estos valores son editables por el dueño antes de guardar.
================================================================ */
function generateReport(){
  const startVal = document.getElementById("report-start").value;
  const endVal   = document.getElementById("report-end").value;
  const catFilter = document.getElementById("report-category").value;

  const start = startVal ? new Date(startVal+"T00:00:00") : null;
  const end   = endVal   ? new Date(endVal+"T23:59:59")   : null;

  const history = JSON.parse(localStorage.getItem("dt_history_v1") || "[]");
  const inRange = history.filter(h=>{
    const d = new Date(h.date);
    return (!start || d >= start) && (!end || d <= end);
  });

  // Cargar compras previamente guardadas (para no perder ediciones manuales)
  const savedPurchases = JSON.parse(localStorage.getItem(LS_PURCHASES) || "{}").items || {};

  const productsToShow = PRODUCTS.filter(p=>{
    if(!ownerActiveCats.includes(p.cat)) return false;
    if(catFilter !== "all" && String(p.cat) !== catFilter) return false;
    return true;
  });

  // Calcular estimado de compra por producto
  const estimates = {};
  productsToShow.forEach(p=>{
    let qtyStart, qtyEnd, wasFaltante=false;

    if(inRange.length > 0){
      qtyStart = inRange[0].items[p.id]?.qty ?? inventoryState.items[p.id].qty;
      qtyEnd   = inRange[inRange.length-1].items[p.id]?.qty ?? inventoryState.items[p.id].qty;
      wasFaltante = inRange.some(h => {
        const it = h.items[p.id];
        return it && (it.manualFaltante || it.qty <= 0);
      });
    } else {
      // Sin registros en el rango: usar el estado actual como referencia
      qtyStart = inventoryState.items[p.id].qty;
      qtyEnd   = inventoryState.items[p.id].qty;
      wasFaltante = isFaltante(p);
    }

    let estimate = Math.max(0, qtyEnd - qtyStart);
    if(wasFaltante) estimate = Math.max(estimate, p.ideal);

    estimates[p.id] = Math.round(estimate*100)/100;
  });

  renderReport(productsToShow, estimates, savedPurchases);
}

// Renderiza el reporte agrupado por categoría con campos editables.
function renderReport(products, estimates, savedPurchases){
  const container = document.getElementById("report-output");
  const byCat = {};
  products.forEach(p=>{ (byCat[p.cat] = byCat[p.cat] || []).push(p); });

  if(products.length===0){
    container.innerHTML = `<p class="missing-empty">No hay productos para mostrar con estos filtros.</p>`;
    return;
  }

  let html = "";
  Object.keys(byCat).forEach(catId=>{
    html += `
      <div class="section">
        <div class="section-head">
          <div class="diamond"></div>
          <h2>${CATEGORIES[catId]}</h2>
          <div class="line"></div>
        </div>
        <div>
          ${byCat[catId].map(p=>{
            const saved = savedPurchases[p.id];
            const value = (saved !== undefined) ? saved : estimates[p.id];
            const decimals = p.step < 1 ? 1 : 0;
            return `
              <div class="purchase-row">
                <span class="dot"></span>
                <span class="pname">${p.name}</span>
                <span class="ideal">ideal: ${p.ideal.toFixed(decimals)} ${p.unit}</span>
                <input type="text" id="purchase-${p.id}" value="${value.toFixed(decimals)}"
                       inputmode="decimal">
                <span class="unit">${p.unit}</span>
              </div>`;
          }).join("")}
        </div>
      </div>`;
  });
  container.innerHTML = html;
}

