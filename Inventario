function savePurchases(){
  const items = {};
  PRODUCTS.forEach(p=>{
    const input = document.getElementById(`purchase-${p.id}`);
    if(input){
      const val = parseFloat(input.value);
      items[p.id] = isNaN(val) ? 0 : val;
    }
